{
  "name": "@cordfast/server",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@cordfast/shared": "workspace:*",
    "@fastify/cors": "^11.3.0",
    "@fastify/jwt": "^10.2.0",
    "@fastify/websocket": "^11.3.0",
    "argon2": "^0.45.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.3.3",
    "fastify-plugin": "^6.0.0",
    "mediasoup": "^3.21.2",
    "postgres": "^3.4.9",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.4",
    "typescript": "~5.8.3"
  }
}
